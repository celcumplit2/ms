---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
}

const {
  title = "Moldstud",
  description = "Light-mode redesign runtime for Moldstud.",
  pageClass = "",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class={pageClass}>
    <slot />
  </body>
</html>
