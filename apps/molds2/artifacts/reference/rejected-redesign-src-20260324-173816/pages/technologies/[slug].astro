---
import DetailPage from "../../components/DetailPage.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { technologies } from "../../data";

export function getStaticPaths() {
  return technologies.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const relatedItems = technologies.filter((item) => item.slug !== entry.slug).slice(0, 2);
---

<SiteLayout title={`${entry.title} | Moldstud`}>
  <DetailPage entry={entry} relatedTitle="Related technologies" relatedItems={relatedItems} relatedHref="/technologies" />
</SiteLayout>
