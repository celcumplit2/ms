---
import ListingPage from "../../components/ListingPage.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { homeFaqs } from "../../data/site-content";
import { solutions } from "../../data";
---

<SiteLayout title="Solutions | Moldstud">
