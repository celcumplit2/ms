---
import type { ActionLink, Metric } from "../data";

interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  metrics?: Metric[];
  primary?: ActionLink;
  secondary?: ActionLink;
  image?: string;
  imageAlt?: string;
  asideTitle?: string;
  asideBody?: string;
}

const {
  eyebrow,
  title,
  intro,
  metrics = [],
  primary,
  secondary,
  image,
  imageAlt = "",
  asideTitle,
  asideBody,
} = Astro.props;
---

<section class="hero">
  <div class="shell hero__grid">
    <div class="hero__copy">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="hero__intro">{intro}</p>

      {(primary || secondary) && (
        <div class="hero__actions">
          {primary && <a class="button button--green" href={primary.href}>{primary.label}</a>}
          {secondary && <a class="button button--blue" href={secondary.href}>{secondary.label}</a>}
        </div>
      )}

      {metrics.length > 0 && (
        <div class="hero__metrics">
          {metrics.map((metric) => (
            <article>
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
            </article>
          ))}
        </div>
      )}
    </div>

    <div class="hero__visual">
      {image && (
        <div class="hero__image-card">
          <img src={image} alt={imageAlt || title} />
        </div>
      )}

      {(asideTitle || asideBody) && (
        <article class="hero__aside-card">
          {asideTitle && <h3>{asideTitle}</h3>}
          {asideBody && <p>{asideBody}</p>}
        </article>
      )}
    </div>
  </div>
</section>
