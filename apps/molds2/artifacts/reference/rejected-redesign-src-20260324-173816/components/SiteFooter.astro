---
import { company, footerGroups } from "../data";
---

<footer class="site-footer">
  <div class="shell site-footer__grid">
    <div class="site-footer__intro">
      <p class="eyebrow eyebrow--footer">Moldstud</p>
      <h2>Build faster with a front-end system that is designed to scale.</h2>
      <p>{company.descriptor}</p>
      <div class="site-footer__actions">
        <a class="button button--green button--sm" href="/hire-us">Start a project</a>
        <a class="button button--blue button--sm" href="/request-profiles">Hire talents</a>
      </div>
    </div>

    <div class="site-footer__links">
      {footerGroups.map((group) => (
        <section>
          <p>{group.title}</p>
          <ul>
            {group.links.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>
</footer>
