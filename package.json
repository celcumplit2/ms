{
  "name": "ms",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev:molds2": "pnpm --dir apps/molds2 dev",
    "build:molds2": "pnpm --dir apps/molds2 build",
    "check:molds2": "pnpm --dir apps/molds2 check",
    "dev:molds_old": "pnpm --dir apps/molds_old dev",
    "build:molds_old": "pnpm --dir apps/molds_old build",
    "check:molds_old": "pnpm --dir apps/molds_old check",
    "check": "pnpm run check:molds2 && pnpm run check:molds_old",
    "rewritegen:bootstrap-targets": "pnpm --dir apps/molds_old run rewritegen:bootstrap-targets",
    "rewritegen:import-pages": "pnpm --dir apps/molds_old run rewritegen:import-pages",
    "rewritegen:import-payload": "pnpm --dir apps/molds_old run rewritegen:import-payload",
    "legacy:extract-blog-dump": "corepack pnpm --dir apps/molds_old run legacy:extract-blog-dump",
    "legacy:build-blog-sqlite": "corepack pnpm --dir apps/molds_old run legacy:build-blog-sqlite",
    "legacy:build-comments-sqlite": "corepack pnpm --dir apps/molds_old run legacy:build-comments-sqlite"
  }
}
